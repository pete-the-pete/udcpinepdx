{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "udcpine wire types",
  "$defs": {
    "Firing": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "ended"
          ]
        }
      },
      "required": [
        "id",
        "started_at",
        "ended_at",
        "status"
      ],
      "additionalProperties": false
    },
    "Sample": {
      "type": "object",
      "properties": {
        "t": {
          "type": "string",
          "format": "date-time"
        },
        "temp_f": {
          "type": "number"
        }
      },
      "required": [
        "t",
        "temp_f"
      ],
      "additionalProperties": false
    },
    "Pizza": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "seq": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "target_seconds": {
          "type": "integer",
          "exclusiveMinimum": 0
        }
      },
      "required": [
        "id",
        "seq",
        "name",
        "started_at",
        "target_seconds"
      ],
      "additionalProperties": false
    },
    "LiveState": {
      "type": "object",
      "properties": {
        "firing": {
          "anyOf": [
            {
              "$ref": "#/$defs/Firing"
            },
            {
              "type": "null"
            }
          ]
        },
        "latest_sample": {
          "anyOf": [
            {
              "$ref": "#/$defs/Sample"
            },
            {
              "type": "null"
            }
          ]
        },
        "active_pizza": {
          "anyOf": [
            {
              "$ref": "#/$defs/Pizza"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "firing",
        "latest_sample",
        "active_pizza"
      ],
      "additionalProperties": false
    }
  }
}
