{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "udcpine wire types",
  "$defs": {
    "Firing": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "ended"
          ]
        }
      },
      "required": [
        "id",
        "started_at",
        "ended_at",
        "status"
      ],
      "additionalProperties": false
    }
  }
}
